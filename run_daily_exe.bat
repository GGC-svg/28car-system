@echo off
chcp 65001 >nul
REM ============================================================
REM 28car.com 每日智能更新排程腳本（獨立執行檔版本）
REM ============================================================

REM 切換到腳本所在目錄
cd /d "%~dp0"

echo ============================================
echo  28Car 每日自動更新
echo  %date% %time%
echo ============================================
echo.

echo [1/2] 執行每日爬蟲...
28car_scraper.exe --daily --stale-days 7

echo.
echo [2/2] 執行每日簡訊發送...
if exist "28car_sms.exe" (
    28car_sms.exe --daily
) else (
    echo      (簡訊功能未安裝，跳過)
)

echo.
echo ============================================
echo  每日任務執行完畢
echo  %date% %time%
echo ============================================
